{
    "version": 2,
    "builds": [
      {
        "src": "backend/main.py",
        "use": "@vercel/python",
        "config": { "maxDuration": 10 }
      },
      {
        "src": "frontend/package.json",
        "use": "@vercel/next"
      }
    ],
    "functions": {
      "backend/main.py": {
        "memory": 1024,
        "maxDuration": 10
      }
    },
    "rewrites": [
      {
        "source": "/api/(.*)",
        "destination": "backend/main.py"
      },
      {
        "source": "/(.*)",
        "destination": "/frontend/$1"
      }
    ]
  }